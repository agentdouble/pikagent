{
  "name": "pickagent",
  "version": "1.0.0",
  "description": "pickagent terminal workspace manager with split panels",
  "main": "main.js",
  "productName": "Pickagent",
  "scripts": {
    "build": "node build.js",
    "start": "node build.js && electron .",
    "dev": "node build.js --watch & electron . &",
    "rebuild": "npx @electron/rebuild",
    "package": "npm run build && electron-builder --mac dir",
    "package:dmg": "npm run build && electron-builder --mac dmg",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.3",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.rekta.pickagent",
    "productName": "Pickagent",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "main/**/*",
      "src/**/*",
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dir"
      ]
    }
  }
}
